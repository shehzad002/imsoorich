# Admin password for /admin panel
ADMIN_PASSWORD=change_me_to_something_secure

# Cloudflare D1 (tools catalog)
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_API_TOKEN=your_api_token_with_d1_edit
CLOUDFLARE_D1_DATABASE_ID=your_d1_database_uuid

# Cloudflare R2 (file storage — supports 200 MB+ per file on free tier)
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=imsoorich-tools
